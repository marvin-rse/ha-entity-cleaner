{
  "compilerOptions": {
    "target": "ES2021",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "experimentalDecorators": true,
    "useDefineForClassFields": false,
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "lib": ["ES2021", "DOM"],
    "outDir": "./dist",
    "declaration": false,
    "sourceMap": false
  },
  "include": ["src/**/*.ts"]
}
